package com.library.controller;

import com.library.common.Result;
import com.library.entity.TransferSuggestion;
import com.library.service.InventoryBalanceService;
import io.swagger.v3.oas.annotations.Operation;
import io.swagger.v3.oas.annotations.Parameter;
import io.swagger.v3.oas.annotations.tags.Tag;
import lombok.extern.slf4j.Slf4j;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.web.bind.annotation.*;

import java.util.List;

//调拨建议管理接口
@Slf4j
@RestController
@RequestMapping("/api/transfer/suggestion")
@Tag(name = "调拨建议管理", description = "主动调拨建议的查询、审批和执行")
public class TransferSuggestionController {

    @Autowired
    private InventoryBalanceService balanceService;

    @GetMapping("/list")
    @Operation(summary = "查询调拨建议列表", description = "查询所有待审批的调拨建议")
    public Result<List<TransferSuggestion>> listSuggestions() {
        try {
            List<TransferSuggestion> suggestions = balanceService.getPendingSuggestions();
            return Result.success("查询成功", suggestions);
        } catch (Exception e) {
            log.error("查询调拨建议列表失败", e);
            return Result.fail("查询失败: " + e.getMessage());
        }
    }

    @GetMapping("/{id}")
    @Operation(summary = "查询调拨建议详情", description = "根据ID查询调拨建议详情")
    public Result<TransferSuggestion> getSuggestion(
            @Parameter(description = "调拨建议ID", required = true)
            @PathVariable Long id) {
        try {
            //TODO: 实现根据ID查询
            return Result.success("查询成功");
        } catch (Exception e) {
            log.error("查询调拨建议详情失败", e);
            return Result.fail("查询失败: " + e.getMessage());
        }
    }

    @PostMapping("/approve/{id}")
    @Operation(summary = "审批通过调拨建议", description = "审批通过调拨建议并执行")
    public Result<Void> approveSuggestion(
            @Parameter(description = "调拨建议ID", required = true)
            @PathVariable Long id,
            @Parameter(description = "审批人ID", required = true)
            @RequestParam Long approverId) {
        try {
            balanceService.approveSuggestion(id, approverId);
            return Result.success("审批通过");
        } catch (Exception e) {
            log.error("审批调拨建议失败", e);
            return Result.fail("审批失败: " + e.getMessage());
        }
    }

    @PostMapping("/reject/{id}")
    @Operation(summary = "拒绝调拨建议", description = "拒绝调拨建议")
    public Result<Void> rejectSuggestion(
            @Parameter(description = "调拨建议ID", required = true)
            @PathVariable Long id,
            @Parameter(description = "审批人ID", required = true)
            @RequestParam Long approverId,
            @Parameter(description = "拒绝原因", required = false)
            @RequestParam(required = false) String reason) {
        try {
            balanceService.rejectSuggestion(id, approverId, reason);
            return Result.success("已拒绝");
        } catch (Exception e) {
            log.error("拒绝调拨建议失败", e);
            return Result.fail("拒绝失败: " + e.getMessage());
        }
    }

    @PostMapping("/trigger-balance")
    @Operation(summary = "手动触发库存平衡分析", description = "手动触发库存平衡分析并生成调拨建议")
    public Result<Void> triggerBalance() {
        try {
            balanceService.triggerManualBalance();
            return Result.success("库存平衡分析已触发");
        } catch (Exception e) {
            log.error("触发库存平衡分析失败", e);
            return Result.fail("触发失败: " + e.getMessage());
        }
    }
}
